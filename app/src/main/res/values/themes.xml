    <style name="Theme.Beta_antiDH" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!--priimario-->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!--2nd -->
        <item name="colorSecondary">@color/blue_light</item>
        <item name="colorSecondaryVariant">@color/blue_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <!--sfondo-->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        
        <item name="windowActionBar">false</item>
